         \\\"server\\\": \\\"misetl\\\",\\n    //         \\\"database\\\": \\\"\\\",\\n    //         \\\"authenticationType\\\": \\\"SqlLogin\\\",\\n    //         \\\"user\\\": \\\"tableau_sa\\\",\\n    //         \\\"password\\\": \\\"\\\",\\n    //         \\\"emptyPasswordInput\\\": false,\\n    //         \\\"savePassword\\\": true,\\n    //         \\\"profileName\\\": \\\"tableau_sa@misetl\\\",\\n    //         \\\"encrypt\\\": \\\"Mandatory\\\",\\n    //         \\\"trustServerCertificate\\\": true,\\n    //         \\\"displayName\\\": \\\"tableau_sa@misetl\\\"\\n    //     }\\n    // ],\\n    // \\\"mssql.enableQueryHistoryCapture\\\": false,\\n    // \\\"mssql.enableRichExperiences\\\": true,\\n    // \\\"mssql.autoDisableNonTSqlLanguageService\\\": false,\\n    // \\\"oracledevtools.connectionConfiguration.walletFileFolder\\\": \\\"/home/daba/Oracle/network/admin\\\",\\n    // \\\"oracledevtools.bookmarkFileFolder\\\": \\\"/home/daba/Oracle/oracle.oracledevtools\\\",\\n    // \\\"oracledevtools.download.otherFolder\\\": \\\"/home/daba/downloads\\\",\\n    // LaTeX Workshop is installed both locally and remotely to escape warnings when opening this file from a remote workspace \\n    // Remote won't work however since the LaTeX modules are not installed.\\n    \\\"workbench.editorAssociations\\\": {\\n        \\\"*.pdf\\\": \\\"latex-workshop-pdf-hook\\\"\\n    },\\n    // Configure [glob patterns](https://aka.ms/vscode-glob-patterns) of file associations to languages (for example `\\\"*.extension\\\": \\\"html\\\"`). \\n    // Patterns will match on the absolute path of a file if they contain a path separator and will match on the name of the file otherwise. \\n    // These have precedence over the default associations of the languages installed.\\n    \\\"files.associations\\\": {\\n        \\\"*.snowsql\\\": \\\"snowflake-sql\\\",\\n        \\\"*.sql\\\": \\\"snowflake-sql\\\",\\n        \\\"*.plsql\\\": \\\"oracle\\\",\\n        \\\"*.ddl\\\": \\\"oracle\\\",\\n        \\\"*.dml\\\": \\\"oracle\\\",\\n        \\\"*.pks\\\": \\\"oracle\\\",\\n        \\\"*.pkb\\\": \\\"oracle\\\"\\n    },\\n    \\\"terminal.integrated.lineHeight\\\": 1.2,\\n    \\\"explorer.confirmDelete\\\": false,\\n    \\\"latex-workshop.latex.recipes\\\": [\\n        {\\n            \\\"name\\\": \\\"latexmk\\\",\\n            \\\"tools\\\": [\\n                \\\"latexmk\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"latexmk (latexmkrc)\\\",\\n            \\\"tools\\\": [\\n                \\\"latexmk_rconly\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"latexmk (lualatex)\\\",\\n            \\\"tools\\\": [\\n                \\\"lualatexmk\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"latexmk (xelatex)\\\",\\n            \\\"tools\\\": [\\n                \\\"xelatexmk\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"pdflatex -> bibtex -> pdflatex * 2\\\",\\n            \\\"tools\\\": [\\n                \\\"pdflatex\\\",\\n                \\\"bibtex\\\",\\n                \\\"pdflatex\\\",\\n                \\\"pdflatex\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"Compile Rnw files\\\",\\n            \\\"tools\\\": [\\n                \\\"rnw2tex\\\",\\n                \\\"latexmk\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"Compile Jnw files\\\",\\n            \\\"tools\\\": [\\n                \\\"jnw2tex\\\",\\n                \\\"latexmk\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"Compile Pnw files\\\",\\n            \\\"tools\\\": [\\n                \\\"pnw2tex\\\",\\n                \\\"latexmk\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"tectonic\\\",\\n            \\\"tools\\\": [\\n                \\\"tectonic\\\"\\n            ]\\n        }\\n    ],\\n    \\\"latex-workshop.latex.au