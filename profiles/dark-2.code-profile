h.action.toggleMaximizedPanel\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"cmd+t cmd+k\\\",\\n        \\\"command\\\": \\\"workbench.action.terminal.kill\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+cmd+u\\\",\\n        \\\"command\\\": \\\"editor.action.transformToUppercase\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+cmd+l\\\",\\n        \\\"command\\\": \\\"editor.action.transformToLowercase\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"alt+cmd+e\\\",\\n        \\\"command\\\": \\\"mssql.runCurrentStatement\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+e\\\",\\n        \\\"command\\\": \\\"-sqldeveloper.connection.folder.edit\\\",\\n        \\\"when\\\": \\\"activeViewlet == 'workbench.view.extension.sqldeveloper-explorer'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+n\\\",\\n        \\\"command\\\": \\\"-sqldeveloper.connection.add\\\",\\n        \\\"when\\\": \\\"activeViewlet == 'workbench.view.extension.sqldeveloper-explorer'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+f9\\\",\\n        \\\"command\\\": \\\"-workbench.action.chat.previousFileTree\\\",\\n        \\\"when\\\": \\\"chatIsEnabled && inChat\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+f9\\\",\\n        \\\"command\\\": \\\"workbench.debug.viewlet.action.disableAllBreakpoints\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+c\\\",\\n        \\\"command\\\": \\\"-workbench.action.terminal.openNativeConsole\\\",\\n        \\\"when\\\": \\\"!terminalFocus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+c\\\",\\n        \\\"command\\\": \\\"-sqldeveloper.connections.focus\\\",\\n        \\\"when\\\": \\\"activeViewlet == 'workbench.view.extension.sqldeveloper-explorer'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+c\\\",\\n        \\\"command\\\": \\\"sqldeveloper.connections.focus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+s\\\",\\n        \\\"command\\\": \\\"snowflakeSearchableObje