{"name":"oracle","icon":"database","settings":"{\"settings\":\"{\\n    \\\"python.terminal.activateEnvironment\\\": true,\\n    \\\"terminal.integrated.shellIntegration.enabled\\\": false,\\n    // to get the default theme color values run the command\\n    // > Developer:Ggenerate Color Theme from Current Settings\\n    \\\"workbench.colorCustomizations\\\": {\\n        \\\"editorStickyScroll.shadow\\\": \\\"#323232\\\",\\n        \\\"tab.border\\\": \\\"#454545\\\",\\n        \\\"tab.unfocusedActiveBorderTop\\\": \\\"#454545\\\",\\n        \\\"editorGroup.border\\\": \\\"#454545\\\",\\n        \\\"editorGroupHeader.border\\\": \\\"#454545\\\",\\n        \\\"panel.border\\\": \\\"#454545\\\",\\n        \\\"sideBar.border\\\": \\\"#454545\\\",\\n        \\\"statusBar.border\\\": \\\"#454545\\\",\\n        \\\"activityBar.border\\\": \\\"#454545\\\",\\n        \\\"editorGroupHeader.tabsBorder\\\": \\\"#454545\\\",\\n        \\\"titleBar.border\\\": \\\"#454545\\\",\\n\\n        \\\"activityBar.activeBorder\\\": \\\"#eb174c\\\",\\n        \\\"activityBar.activeBackground\\\": \\\"#eb174c\\\",\\n        \\\"activityBarBadge.background\\\": \\\"#eb174c\\\",\\n        \\\"tab.activeBorderTop\\\": \\\"#eb174c\\\",\\n\\n\\n        \\\"tab.activeBorder\\\": \\\"#262629\\\",\\n        \\\"editor.wordHighlightBorder\\\": \\\"#262629\\\",\\n        \\\"editor.background\\\": \\\"#262629\\\",\\n        \\\"sideBar.background\\\": \\\"#262629\\\",\\n        \\\"activityBar.inactiveBackground\\\": \\\"#262629\\\",\\n        \\\"panel.background\\\": \\\"#262629\\\",\\n        \\\"terminal.background\\\": \\\"#262629\\\",\\n        \\\"tab.activeBackground\\\": \\\"#262629\\\",\\n        \\\"tab.inactiveBackground\\\": \\\"#262629\\\",\\n        \\\"editorGroupHeader.tabsBackground\\\": \\\"#262629\\\",\\n        \\\"editorGroupHeader.noTabsBackground\\\": \\\"#262629\\\",\\n\\n        \\\"activityBar.background\\\": \\\"#262629\\\",\\n        \\\"sideBarSectionHeader.background\\\": \\\"#262629\\\",\\n        \\\"titleBar.activeBackground\\\": \\\"#262629\\\",\\n        \\\"titleBar.inactiveBackground\\\": \\\"#262629\\\",\\n        \\\"statusBar.background\\\": \\\"#262629\\\",\\n        \\\"statusBar.noFolderBackground\\\": \\\"#262629\\\",\\n        \\\"statusBarItem.remoteBackground\\\": \\\"#262629\\\",\\n\\n        \\\"gitDecoration.ignoredResourceForeground\\\": \\\"#6c6d6e\\\",\\n        \\\"gitDecoration.modifiedResourceForeground\\\": \\\"#e7b017\\\",\\n        \\\"gitDecoration.untrackedResourceForeground\\\": \\\"#069460\\\",\\n        \\\"editor.wordHighlightBackground\\\": \\\"#00bcd440\\\",\\n        \\\"editor.wordHighlightStrongBackground\\\": \\\"#ff800055\\\",\\n        \\\"editorIndentGuide.background1\\\": \\\"#444444\\\",\\n        \\\"editorIndentGuide.activeBackground1\\\": \\\"#b72d03dc\\\",\\n        \\\"editorRuler.foreground\\\": \\\"#3a3a3a\\\",\\n\\n        // \\\"statusBar.debuggingBackground\\\": \\\"#eb174c\\\",\\n        // \\\"editor.wordHighlightBackground\\\": \\\"#00bcd440\\\",\\n        // \\\"editor.wordHighlightStrongBackground\\\": \\\"#ff800055\\\",\\n        // \\\"sideBar.background\\\": \\\"#2b2b2b\\\",\\n        // \\\"editorGutter.background\\\": \\\"#2b2b2b\\\",\\n        // \\\"editorIndentGuide.background1\\\": \\\"#444444\\\",\\n        // current scope indent line\\n        // \\\"editorIndentGuide.activeBackground1\\\": \\\"#b72d03dc\\\",\\n        // right margin color\\n        // \\\"editorRuler.foreground\\\": \\\"#3a3a3a\\\",\\n        // \\\"notebook.cellEditorBackground\\\": \\\"#2e2e2e\\\",\\n        // \\\"notebook.focusedCellBackground\\\": \\\"#2e2e2e\\\",\\n        // \\\"notebook.cellHoverBackground\\\": \\\"#2e2e2e\\\",\\n        // \\\"notebook.focusedEditorBorder\\\": \\\"#3187d2\\\",\\n        // \\\"notebook.focusedCellBorder\\\":\\\"#3187d2\\\"\\n        // change the color of the files in .gitignore\\n        // \\\"gitDecoration.submoduleResourceForeground\\\": \\\"#6a737d\\\",\\n        // \\\"editor.wordHighlightBorder\\\": \\\"#24292e\\\",\\n        // \\\"sideBar.background\\\": \\\"#2b2b2b\\\",\\n        // \\\"editorGutter.background\\\": \\\"#2b2b2b\\\",\\n        // current scope indent line\\n        // right margin color\\n        // \\\"notebook.cellEditorBackground\\\": \\\"#2e2e2e\\\",\\n        // \\\"notebook.focusedCellBackground\\\": \\\"#2e2e2e\\\",\\n        // \\\"notebook.cellHoverBackground\\\": \\\"#2e2e2e\\\",\\n        // \\\"notebook.focusedEditorBorder\\\": \\\"#3187d2\\\",\\n        // \\\"notebook.focusedCellBorder\\\":\\\"#3187d2\\\"\\n    },\\n    // Use rulers in text editors but not in jupyter notebooks\\n    \\\"editor.rulers\\\": [128],\\n    // Don't show rules in notebook cells\\n    \\\"notebook.editorOptionsCustomizations\\\": {\\\"editor.rulers\\\": []},\\n    \\\"editor.renderWhitespace\\\": \\\"boundary\\\",\\n\\n    \\\"[oraclesql]\\\": {\\n        \\\"editor.suggest.showSnippets\\\": true,\\n        \\\"editor.quickSuggestions\\\": {\\n            \\\"comments\\\": \\\"on\\\",\\n            \\\"strings\\\": \\\"on\\\",\\n            \\\"other\\\": \\\"on\\\"\\n        }\\n    },\\n    // Configure [glob patterns](https://aka.ms/vscode-glob-patterns) of file associations to languages (for example `\\\"*.extension\\\": \\\"html\\\"`). \\n    // Patterns will match on the absolute path of a file if they contain a path separator and will match on the name of the file otherwise. \\n    // These have precedence over the default associations of the languages installed.\\n    \\\"files.associations\\\": {\\n        \\\"*.sql\\\": \\\"oracle-sql\\\",\\n        \\\"*.plsql\\\": \\\"oracle-sql\\\",\\n        \\\"*.ddl\\\": \\\"oracle-sql\\\",\\n        \\\"*.dml\\\": \\\"oracle-sql\\\",\\n        \\\"*.pks\\\": \\\"oracle-sql\\\",\\n        \\\"*.pkb\\\": \\\"oracle-sql\\\"\\n    },\\n    \\\"terminal.integrated.lineHeight\\\": 1.2,\\n    \\\"explorer.confirmDelete\\\": false,\\n\\n    \\\"git.openRepositoryInParentFolders\\\": \\\"always\\\",\\n    \\\"github.copilot.enable\\\": {\\n        \\\"*\\\": false,\\n        \\\"plaintext\\\": false,\\n        \\\"markdown\\\": false,\\n        \\\"scminput\\\": false\\n    },\\n    \\\"jupyter.askForKernelRestart\\\": false,\\n    \\\"editor.accessibilitySupport\\\": \\\"off\\\",\\n    \\\"terminal.integrated.enableMultiLinePasteWarning\\\": \\\"never\\\",\\n    \\\"notebook.output.textLineLimit\\\": 128,\\n    \\\"notebook.lineNumbers\\\": \\\"on\\\",\\n    \\\"terminal.integrated.allowedLinkSchemes\\\": [\\n        \\\"file\\\",\\n        \\\"http\\\",\\n        \\\"https\\\",\\n        \\\"mailto\\\",\\n        \\\"vscode\\\",\\n        \\\"vscode-insiders\\\",\\n        \\\"docker-desktop\\\"\\n    ],\\n    \\\"terminal.integrated.tabs.location\\\": \\\"left\\\",\\n    \\\"terminal.integrated.tabs.enabled\\\": false,\\n    \\\"[dockercompose]\\\": {\\n        \\\"editor.insertSpaces\\\": true,\\n        \\\"editor.tabSize\\\": 2,\\n        \\\"editor.autoIndent\\\": \\\"advanced\\\",\\n        \\\"editor.quickSuggestions\\\": {\\n            \\\"other\\\": true,\\n            \\\"comments\\\": false,\\n            \\\"strings\\\": true\\n        },\\n    },\\n    \\\"github.copilot.nextEditSuggestions.enabled\\\": true,\\n    \\\"explorer.confirmDragAndDrop\\\": false,\\n    \\\"editor.unicodeHighlight.ambiguousCharacters\\\": false,\\n    \\\"editor.fontFamily\\\": \\\"JetBrains Mono\\\",\\n    \\\"editor.fontLigatures\\\": true,\\n    \\\"chat.viewSessions.orientation\\\": \\\"stacked\\\",\\n    \\\"chat.mcp.gallery.enabled\\\": true,\\n    \\\"workbench.colorTheme\\\": \\\"DuoTone Dark Sea\\\",\\n    \\\"chat.tools.terminal.autoApprove\\\": {\\n        \\\"uv\\\": true,\\n        \\\"git rev-parse\\\": true,\\n        \\\"git ls-tree\\\": true,\\n        \\\"make\\\": true\\n    },\\n\\n    \\\"sqldeveloper.datagrid.fontFamily\\\": \\\"'Menlo', 'Droid Sans Mono', monospace\\\",\\n    \\\"sqldeveloper.sqlHistory.historyLimit\\\": 500,\\n}   \\n\"}","keybindings":"{\"keybindings\":\"// Place your key bindings in this file to override the defaults\\n[\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+d\\\",\\n        \\\"command\\\": \\\"workbench.view.extension.objectExplorer\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"alt+cmd+d\\\",\\n        \\\"command\\\": \\\"-workbench.view.extension.objectExplorer\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+c\\\",\\n        \\\"command\\\": \\\"mssql.connect\\\",\\n        \\\"when\\\": \\\"editorTextFocus && editorLangId == 'sql'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+c\\\",\\n        \\\"command\\\": \\\"-mssql.connect\\\",\\n        \\\"when\\\": \\\"editorTextFocus && editorLangId == 'sql'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+e\\\",\\n        \\\"command\\\": \\\"-cursorLineEndSelect\\\",\\n        \\\"when\\\": \\\"textInputFocus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+f2\\\",\\n        \\\"command\\\": \\\"workbench.action.toggleMaximizedPanel\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"cmd+t cmd+k\\\",\\n        \\\"command\\\": \\\"workbench.action.terminal.kill\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+cmd+u\\\",\\n        \\\"command\\\": \\\"editor.action.transformToUppercase\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+cmd+l\\\",\\n        \\\"command\\\": \\\"editor.action.transformToLowercase\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"alt+cmd+e\\\",\\n        \\\"command\\\": \\\"mssql.runCurrentStatement\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+e\\\",\\n        \\\"command\\\": \\\"-sqldeveloper.connection.folder.edit\\\",\\n        \\\"when\\\": \\\"activeViewlet == 'workbench.view.extension.sqldeveloper-explorer'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+n\\\",\\n        \\\"command\\\": \\\"-sqldeveloper.connection.add\\\",\\n        \\\"when\\\": \\\"activeViewlet == 'workbench.view.extension.sqldeveloper-explorer'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+f9\\\",\\n        \\\"command\\\": \\\"-workbench.action.chat.previousFileTree\\\",\\n        \\\"when\\\": \\\"chatIsEnabled && inChat\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+f9\\\",\\n        \\\"command\\\": \\\"workbench.debug.viewlet.action.disableAllBreakpoints\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+c\\\",\\n        \\\"command\\\": \\\"-workbench.action.terminal.openNativeConsole\\\",\\n        \\\"when\\\": \\\"!terminalFocus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+c\\\",\\n        \\\"command\\\": \\\"-sqldeveloper.connections.focus\\\",\\n        \\\"when\\\": \\\"activeViewlet == 'workbench.view.extension.sqldeveloper-explorer'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+c\\\",\\n        \\\"command\\\": \\\"sqldeveloper.connections.focus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+s\\\",\\n        \\\"command\\\": \\\"snowflakeSearchableObjectExplorer.focus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+x\\\",\\n        \\\"command\\\": \\\"chatgpt.openSidebar\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+cmd+w\\\",\\n        \\\"command\\\": \\\"sqldeveloper.connection.folder.open.worksheet\\\",\\n        \\\"when\\\": \\\"activeViewlet == 'workbench.view.extension.sqldeveloper-explorer' && viewItem != 'CONNECTING_CONNECTION_FOLDER'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+w\\\",\\n        \\\"command\\\": \\\"-sqldeveloper.connection.folder.open.worksheet\\\",\\n        \\\"when\\\": \\\"activeViewlet == 'workbench.view.extension.sqldeveloper-explorer' && viewItem != 'CONNECTING_CONNECTION_FOLDER'\\\"\\n    }\\n]\",\"platform\":1}","extensions":"[{\"identifier\":{\"id\":\"anan.jetbrains-darcula-theme\",\"uuid\":\"f6c61e3b-6055-461e-9798-1b3e4baccb18\"},\"displayName\":\"JetBrains Darcula Theme\",\"applicationScoped\":false},{\"identifier\":{