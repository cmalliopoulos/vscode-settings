op\\\": false,\\n    \\\"claudeCode.preferredLocation\\\": \\\"panel\\\",\\n    \\\"geminicodeassist.project\\\": \\\"gemini-ai-for-developers\\\",\\n    \\\"geminicodeassist.displayInlineContextHint\\\": false,\\n    \\\"diffEditor.codeLens\\\": true,\\n    \\\"chat.tools.urls.autoApprove\\\": {\\n        \\\"https://code.visualstudio.com\\\": true,\\n        \\\"https://github.com/microsoft/vscode/wiki/*\\\": true,\\n        \\\"https://reference.langchain.com\\\": true,\\n        \\\"https://raw.githubusercontent.com\\\": {\\n            \\\"approveRequest\\\": false,\\n            \\\"approveResponse\\\": true\\n        },\\n        \\\"https://docs.astral.sh\\\": true,\\n        \\\"https://marketplace.visualstudio.com\\\": {\\n            \\\"approveRequest\\\": false,\\n            \\\"approveResponse\\\": true\\n        }\\n    },\\n    \\\"chat.tools.terminal.autoApprove\\\": {\\n        \\\"env\\\": true,\\n        \\\"setopt\\\": true,\\n        \\\"printf\\\": true,\\n        \\\"git blame\\\": true,\\n        \\\"/^/Users/christos/projects/remotes/relationalai/playground/text2pyrel/\\\\\\\\.venv/bin/python - <<'PY'\\\\nimport inspect\\\\nfrom relationalai\\\\\\\\.semantics\\\\\\\\.frontend\\\\\\\\.base import Model\\\\nprint\\\\\\\\('Model file:', inspect\\\\\\\\.getsourcefile\\\\\\\\(Model\\\\\\\\)\\\\\\\\)\\\\nprint\\\\\\\\('\\\\\\\\\\\\\\\\nModel\\\\\\\\._get_executor source:\\\\\\\\\\\\\\\\n'\\\\\\\\)\\\\nprint\\\\\\\\(inspect\\\\\\\\.getsource\\\\\\\\(Model\\\\\\\\._get_executor\\\\\\\\)\\\\\\\\)\\\\nexecutor = Model\\\\\\\\._get_executor\\\\nPY$/\\\": {\\n            \\\"approve\\\": true,\\n            \\\"matchCommandLine\\\": true\\n        },\\n        \\\"kpsewhich\\\": true,\\n        \\\"true\\\": true,\\n        \\\"strings\\\": true\\n    },\\n    \\\"chat.viewSessions.orientation\\\": \\\"stacked\\\",\\n    \\\"gitlens.ai.model\\\": \\\"vscode\\\",\\n    \\\"gitlens.ai.vscode.model\\\": \\\"copilot:gpt-4.1\\\",\\n    // // Using the light mode\\n    // // \\\"indentRainbow.indicatorStyle\\\": \\\"light\\\",\\n    // // we use a simple 1 pixel wide line\\n    // \\\"indentRainbow.lightIndicatorStyleLineWidth\\\": 0,\\n    // \\\"indentRainbow.colors\\\": [\\n    //     \\\"rgba(255,255,64,0.04)\\\",\\n    //     \\\"rgba(127,255,127,0.02)\\\",\\n    //     \\\"rgba(255,127,255,0.04)\\\",\\n    //     \\\"rgba(79,236,236,0.04)\\\"\\n    // ],\\n    // // The indent color if the number of spaces is not a multiple of \\\"tabSize\\\".\\n    // \\\"indentRainbow.errorColor\\\": \\\"rgba(10,32,32,0.01)\\\",\\n    // // The indent color when there is a mix between spaces and tabs.\\n    // // To be disabled this coloring set this to an empty string.\\n    // \\\"indentRainbow.tabmixColor\\\": \\\"rgba(10,32,32,0.01)\\\"\\n}\"}","keybindings":"{\"keybindings\":\"// Place your key bindings in this file to override the defaults\\n[\\n    {\\n        \\\"key\\\": \\\"alt+cmd+d\\\",\\n        \\\"command\\\": \\\"-workbench.view.extension.objectExplorer\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+c\\\",\\n        \\\"command\\\": \\\"mssql.connect\\\",\\n        \\\"when\\\": \\\"editorTextFocus && editorLangId == 'sql'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+c\\\",\\n        \\\"command\\\": \\\"-mssql.connect\\\",\\n        \\\"when\\\": \\\"editorTextFocus && editorLangId == 'sql'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+e\\\",\\n        \\\"command\\\": \\\"-cursorLineEndSelect\\\",\\n        \\\"when\\\": \\\"textInputFocus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+f2\\\",\\n        \\\"command\\\": \\\"workbench.action.toggleMaximizedPanel\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"cmd+t cmd+k\\\",\\n        \\\"command\\\": \\\"workbench.action.terminal.kill\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+cmd+u\\\",\\n        \\\"command\\\": \\\"editor.action.transformToUppercase\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+cmd+l\\\",\\n        \\\"command\\\": \\\"editor.action.transformToLowercase\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"alt+cmd+e\\\",\\n        \\\"command\\\": \\\"mssql.runCurrentStatement\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+e\\\",\\n        \\\"command\\\": \\\"-sqldeveloper.connection.folder.edit\\\",\\n        \\\"when\\\": \\\"activeViewlet == 'workbench.view.extension.sqldeveloper-explorer'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+n\\\",\\n        \\\"command\\\": \\\"-sqldeveloper.connection.add\\\",\\n        \\\"when\\\": \\\"activeViewlet == 'workbench.view.extension.sqldeveloper-explorer'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+f9\\\",\\n        \\\"command\\\": \\\"-workbench.action.chat.previousFileTree\\\",\\n        \\\"when\\\": \\\"chatIsEnabled && inChat\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+f9\\\",\\n        \\\"command\\\": \\\"workbench.debug.viewlet.action.disableAllBreakpoints\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+c\\\",\\n        \\\"command\\\": \\\"-workbench.action.terminal.openNativeConsole\\\",\\n        \\\"when\\\": \\\"!terminalFocus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+c\\\",\\n        \\\"command\\\": \\\"-sqldeveloper.connections.focus\\\",\\n        \\\"when\\\": \\\"activeViewlet == 'workbench.view.extension.sqldeveloper-explorer'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+c\\\",\\n        \\\"command\\\": \\\"sqldeveloper.connections.focus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+x\\\",\\n        \\\"command\\\": \\\"chatgpt.openSidebar\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+cmd+c\\\",\\n        \\\"command\\\": \\\"workbench.view.extension.claude-sidebar-secondary\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"cmd+t cmd+e\\\",\\n        \\\"command\\\": \\\"workbench.action.createTerminalEditor\\\",\\n        \\\"when\\\": \\\"terminalProcessSupported\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"alt+g\\\",\\n        \\\"command\\\": \\\"-cloudcode.gemini.chatView.focus\\\",\\n        \\\"when\\\": \\\"!inputFocus && !runningOnCloudShell\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"alt+cmd+g\\\",\\n        \\\"command\\\": \\\"-workbench.view.extension.geminiChat\\\",\\n        \\\"when\\\": \\\"viewContainer.workbench.view.extension.geminiChat.enabled && !runningOnCloudShell\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+cmd+g\\\",\\n        \\\"command\\\": \\\"workbench.view.extension.geminiChat\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+b\\\",\\n        \\\"command\\\": \\\"workbench.debug.viewlet.action.removeAllBreakpoints\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+; m\\\",\\n        \\\"command\\\": \\\"-jupyter.changeCellToMarkdown\\\",\\n        \\\"when\\\": \\\"editorTextFocus && jupyter.hascodecells && !jupyter.webExtension && !notebookEditorFocused\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+cmd+s\\\",\\n        \\\"command\\\": \\\"snowflakeAccount.focus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+d\\\",\\n        \\\"command\\\": \\\"workbench.view.extension.duckdb-explorer\\\"\\n    }\\n]\",\"platform\":1}","extensions":"[{\"identifier\":{\"id\":\"aaron-bond.better-comments\",\"uuid\":\"7a0110bb-231a-4598-aa1b-0769ea46d28b\"},\"displayName\":\"Better Comments\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"anan.jetbrains-darcula-theme\",\"uuid\":\"f6c61e3b-6055-461e-9798-1b3e4baccb18\"},\"displayName\":\"JetBrains Darcula Theme\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"anthropic.claude-code\",\"uuid\":\"3c13ae49-babe-45fe-8c48-5e45077a62bf\"},\"displayName\":\"Claude Code for VS Code\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"cedricverlinden.cursor-dark\",\"uuid\":\"2d3724af-3c3f-4c4e-abb8-c5cdb95f3677\"},\"displayName\":\"Cursor Dark\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"chuckjonas.duc