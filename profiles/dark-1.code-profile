{"name":"dark-1","icon":"snake","settings":"{\"settings\":\"{\\n    // \\\"security.workspace.trust.untrustedFiles\\\": \\\"open\\\",\\n    // \\\"sqldeveloper.telemetry.enabled\\\": false,\\n    // \\\"oracledevtools.connectionConfiguration.configFilesFolder\\\": \\\"/home/daba/Oracle/network/admin\\\",\\n    \\\"python.terminal.activateEnvironment\\\": true,\\n    \\\"python.terminal.useEnvFile\\\": true,\\n    // This is crucial: if set to true innexplicable things happen like running the venv activation twice.\\n    \\\"terminal.integrated.shellIntegration.enabled\\\": false,\\n    \\\"terminal.integrated.lineHeight\\\": 1.2,\\n    \\\"terminal.integrated.allowedLinkSchemes\\\": [\\n        \\\"file\\\",\\n        \\\"http\\\",\\n        \\\"https\\\",\\n        \\\"mailto\\\",\\n        \\\"vscode\\\",\\n        \\\"vscode-insiders\\\",\\n        \\\"docker-desktop\\\"\\n    ],\\n    \\\"terminal.integrated.tabs.enabled\\\": false,\\n    \\\"terminal.integrated.tabs.location\\\": \\\"left\\\",\\n    \\\"terminal.integrated.enableMultiLinePasteWarning\\\": \\\"never\\\",\\n    // \\\"terminal.integrated.fontSize\\\": 12,\\n    \\\"workbench.colorCustomizations\\\": {\\n        // \\\"editorIndentGuide.background1\\\": \\\"#333444\\\",\\n        // current scope indent line\\n        \\\"editorIndentGuide.activeBackground1\\\": \\\"#a12803dc\\\",\\n        \\\"editorRuler.foreground\\\": \\\"#3a3a3a\\\"\\n    },\\n    \\\"editor.fontFamily\\\": \\\"JetBrains Mono\\\",\\n    \\\"editor.fontLigatures\\\": true,\\n    // Use rulers in text editors but not in jupyter notebooks\\n    \\\"editor.accessibilitySupport\\\": \\\"off\\\",\\n    \\\"editor.rulers\\\": [\\n        128\\n    ],\\n    \\\"editor.renderWhitespace\\\": \\\"boundary\\\",\\n    \\\"editor.unicodeHighlight.ambiguousCharacters\\\": false,\\n    \\\"notebook.editorOptionsCustomizations\\\": {\\n        \\\"editor.rulers\\\": []\\n    },\\n    \\\"[oraclesql]\\\": {\\n        \\\"editor.suggest.showSnippets\\\": true,\\n        \\\"editor.quickSuggestions\\\": {\\n            \\\"comments\\\": \\\"on\\\",\\n            \\\"strings\\\": \\\"on\\\",\\n            \\\"other\\\": \\\"on\\\"\\n        }\\n    },\\n    // \\\"mssql.connections\\\": [\\n    //     {\\n    //         \\\"server\\\": \\\"misetl\\\",\\n    //         \\\"database\\\": \\\"\\\",\\n    //         \\\"authenticationType\\\": \\\"SqlLogin\\\",\\n    //         \\\"user\\\": \\\"cmalliopoulos\\\",\\n    //         \\\"password\\\": \\\"\\\",\\n    //         \\\"emptyPasswordInput\\\": false,\\n    //         \\\"savePassword\\\": true,\\n    //         \\\"profileName\\\": \\\"cmalliopoulos@misetl\\\",\\n    //         \\\"encrypt\\\": \\\"Mandatory\\\",\\n    //         \\\"trustServerCertificate\\\": true,\\n    //         \\\"connectTimeout\\\": 15,\\n    //         \\\"commandTimeout\\\": 30,\\n    //         \\\"applicationName\\\": \\\"vscode-mssql\\\",\\n    //         \\\"displayName\\\": \\\"cmalliopoulos@misetl\\\"\\n    //     },\\n    //     {\\n    //         \\\"server\\\": \\\"misetl\\\",\\n    //         \\\"database\\\": \\\"\\\",\\n    //         \\\"authenticationType\\\": \\\"SqlLogin\\\",\\n    //         \\\"user\\\": \\\"tableau_sa\\\",\\n    //         \\\"password\\\": \\\"\\\",\\n    //         \\\"emptyPasswordInput\\\": false,\\n    //         \\\"savePassword\\\": true,\\n    //         \\\"profileName\\\": \\\"tableau_sa@misetl\\\",\\n    //         \\\"encrypt\\\": \\\"Mandatory\\\",\\n    //         \\\"trustServerCertificate\\\": true,\\n    //         \\\"displayName\\\": \\\"tableau_sa@misetl\\\"\\n    //     }\\n    // ],\\n    // \\\"mssql.enableQueryHistoryCapture\\\": false,\\n    // \\\"mssql.enableRichExperiences\\\": true,\\n    // \\\"mssql.autoDisableNonTSqlLanguageService\\\": false,\\n    // \\\"oracledevtools.connectionConfiguration.walletFileFolder\\\": \\\"/home/daba/Oracle/network/admin\\\",\\n    // \\\"oracledevtools.bookmarkFileFolder\\\": \\\"/home/daba/Oracle/oracle.oracledevtools\\\",\\n    // \\\"oracledevtools.download.otherFolder\\\": \\\"/home/daba/downloads\\\",\\n    // LaTeX Workshop is installed both locally and remotely to escape warnings when opening this file from a remote workspace \\n    // Remote won't work however since the LaTeX modules are not installed.\\n    \\\"workbench.editorAssociations\\\": {\\n        \\\"*.pdf\\\": \\\"latex-workshop-pdf-hook\\\"\\n    },\\n    // Configure [glob patterns](https://aka.ms/vscode-glob-patterns) of file associations to languages (for example `\\\"*.extension\\\": \\\"html\\\"`). \\n    // Patterns will match on the absolute path of a file if they contain a path separator and will match on the name of the file otherwise. \\n    // These have precedence over the default associations of the languages installed.\\n    \\\"files.associations\\\": {\\n        \\\"*.snowsql\\\": \\\"snowflake-sql\\\",\\n        \\\"*.sql\\\": \\\"snowflake-sql\\\",\\n        \\\"*.plsql\\\": \\\"oracle\\\",\\n        \\\"*.ddl\\\": \\\"oracle\\\",\\n        \\\"*.dml\\\": \\\"oracle\\\",\\n        \\\"*.pks\\\": \\\"oracle\\\",\\n        \\\"*.pkb\\\": \\\"oracle\\\"\\n    },\\n    \\\"explorer.confirmDelete\\\": false,\\n    \\\"latex-workshop.latex.recipes\\\": [\\n        {\\n            \\\"name\\\": \\\"latexmk\\\",\\n            \\\"tools\\\": [\\n                \\\"latexmk\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"latexmk (latexmkrc)\\\",\\n            \\\"tools\\\": [\\n                \\\"latexmk_rconly\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"latexmk (lualatex)\\\",\\n            \\\"tools\\\": [\\n                \\\"lualatexmk\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"latexmk (xelatex)\\\",\\n            \\\"tools\\\": [\\n                \\\"xelatexmk\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"pdflatex -> bibtex -> pdflatex * 2\\\",\\n            \\\"tools\\\": [\\n                \\\"pdflatex\\\",\\n                \\\"bibtex\\\",\\n                \\\"pdflatex\\\",\\n                \\\"pdflatex\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"Compile Rnw files\\\",\\n            \\\"tools\\\": [\\n                \\\"rnw2tex\\\",\\n                \\\"latexmk\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"Compile Jnw files\\\",\\n            \\\"tools\\\": [\\n                \\\"jnw2tex\\\",\\n                \\\"latexmk\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"Compile Pnw files\\\",\\n            \\\"tools\\\": [\\n                \\\"pnw2tex\\\",\\n                \\\"latexmk\\\"\\n            ]\\n        },\\n        {\\n            \\\"name\\\": \\\"tectonic\\\",\\n            \\\"tools\\\": [\\n                \\\"tectonic\\\"\\n            ]\\n        }\\n    ],\\n    \\\"latex-workshop.latex.autoBuild.run\\\": \\\"onSave\\\",\\n    \\\"git.openRepositoryInParentFolders\\\": \\\"never\\\",\\n    \\\"github.copilot.enable\\\": {\\n        \\\"*\\\": false,\\n        \\\"plaintext\\\": false,\\n        \\\"markdown\\\": false,\\n        \\\"scminput\\\": false\\n    },\\n    \\\"latex-workshop.latex.autoClean.run\\\": \\\"onFailed\\\",\\n    \\\"jupyter.askForKernelRestart\\\": false,\\n    \\\"cSpell.language\\\": \\\"en,el\\\",\\n    \\\"cSpell.enabledFileTypes\\\": {\\n        \\\"oracle\\\": false,\\n        \\\"python\\\": false,\\n        \\\"dockerfile\\\": false\\n    },\\n    \\\"snowflake.connectionsConfigFile\\\": \\\"/Users/christos/.snowflake/connections.toml\\\",\\n    \\\"snowflake.enableNativeAppPanel\\\": true,\\n    \\\"redhat.telemetry.enabled\\\": true,\\n    \\\"workbench.colorTheme\\\": \\\"GitHub Dark Dimmed\\\",\\n    \\\"makefile.configureOnOpen\\\": true,\\n    \\\"notebook.output.textLineLimit\\\": 128,\\n    \\\"notebook.lineNumbers\\\": \\\"on\\\",