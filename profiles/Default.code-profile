{"name":"Default","settings":"{\"settings\":\"// to get the default theme color values run the command\\n// > Developer:Ggenerate Color Theme from Current Settings\\n{\\n    // Controls the dispatching logic for key presses to use either `code` (recommended) or `keyCode`.\\n    // \\\"keyboard.dispatch\\\": \\\"keyCode\\\",\\n    \\\"workbench.colorTheme\\\": \\\"GitHub Dark Default\\\",\\n    \\n    \\\"workbench.colorCustomizations\\\": {\\n        \\\"tab.border\\\": \\\"#464646\\\",\\n        \\\"tab.unfocusedActiveBorderTop\\\": \\\"#464646\\\",\\n        \\\"editorGroup.border\\\": \\\"#464646\\\",\\n        \\\"editorGroupHeader.border\\\": \\\"#464646\\\",\\n        \\\"panel.border\\\": \\\"#464646\\\",\\n        \\\"sideBar.border\\\": \\\"#464646\\\",\\n        \\\"titleBar.border\\\": \\\"#464646\\\",\\n        \\\"statusBar.border\\\": \\\"#464646\\\",\\n        \\\"activityBar.border\\\": \\\"#464646\\\",\\n        \\\"editorGroupHeader.tabsBorder\\\": \\\"#464646\\\",\\n\\n        \\\"editor.background\\\": \\\"#29292b\\\",\\n        \\\"tab.activeBorder\\\": \\\"#29292b\\\",\\n        \\\"sideBar.background\\\": \\\"#29292b\\\",\\n        \\\"activityBar.inactiveBackground\\\": \\\"#29292b\\\",\\n        \\\"panel.background\\\": \\\"#29292b\\\",\\n        \\\"terminal.background\\\": \\\"#29292b\\\",\\n        \\\"editorGroupHeader.tabsBackground\\\": \\\"#29292b\\\",\\n        \\\"editorGroupHeader.noTabsBackground\\\": \\\"#29292b\\\",\\n        \\\"tab.activeBackground\\\": \\\"#29292b\\\",\\n        \\\"tab.inactiveBackground\\\": \\\"#29292b\\\",\\n\\n        \\\"sideBarSectionHeader.background\\\": \\\"#353839\\\",\\n        \\\"activityBar.background\\\": \\\"#353839\\\",\\n        \\\"titleBar.activeBackground\\\": \\\"#353839\\\",\\n\\n        \\\"titleBar.inactiveBackground\\\": \\\"#2c2c2c\\\",\\n        \\\"statusBar.background\\\": \\\"#2c2c2c\\\",\\n        \\\"statusBar.noFolderBackground\\\": \\\"#2c2c2c\\\",\\n\\n        \\\"statusBar.debuggingBackground\\\": \\\"#3a3a3a\\\",\\n        \\\"editorRuler.foreground\\\": \\\"#3a3a3a\\\",\\n\\n        \\\"tab.activeBorderTop\\\": \\\"#01dca5\\\",\\n        \\\"editor.wordHighlightBorder\\\": \\\"#24292e\\\",\\n\\n        \\\"editor.wordHighlightBackground\\\": \\\"#00bcd440\\\",\\n        \\\"editor.wordHighlightStrongBackground\\\": \\\"#ff800055\\\",\\n        // \\\"sideBar.background\\\": \\\"#2b2b2b\\\",\\n        // \\\"editorGutter.background\\\": \\\"#2b2b2b\\\",\\n        \\\"editorIndentGuide.background1\\\": \\\"#444444\\\",\\n        // current scope indent line\\n        \\\"editorIndentGuide.activeBackground1\\\": \\\"#b72d03dc\\\",\\n        // right margin color\\n        // \\\"notebook.cellEditorBackground\\\": \\\"#2e2e2e\\\",\\n        // \\\"notebook.focusedCellBackground\\\": \\\"#2e2e2e\\\",\\n        // \\\"notebook.cellHoverBackground\\\": \\\"#2e2e2e\\\",\\n        // \\\"notebook.focusedEditorBorder\\\": \\\"#3187d2\\\",\\n        // \\\"notebook.focusedCellBorder\\\":\\\"#3187d2\\\"\\n        // change the color of the files in .gitignore\\n        \\\"gitDecoration.ignoredResourceForeground\\\": \\\"#6c6d6e\\\",\\n        \\\"gitDecoration.modifiedResourceForeground\\\": \\\"#e7b017\\\",\\n        // \\\"gitDecoration.submoduleResourceForeground\\\": \\\"#6a737d\\\",\\n        \\\"gitDecoration.untrackedResourceForeground\\\": \\\"#069460\\\"\\n    },\\n    // Use rulers in text editors but not in jupyter notebooks\\n    \\\"editor.rulers\\\": [128],\\n    \\\"notebook.editorOptionsCustomizations\\\": {\\n        \\\"editor.rulers\\\": []\\n    },\\n    \\\"editor.renderWhitespace\\\": \\\"boundary\\\",\\n    \\\"security.workspace.trust.untrustedFiles\\\": \\\"open\\\",\\n    // \\\"sqldeveloper.telemetry.enabled\\\": true,\\n    // \\\"oracledevtools.connectionConfiguration.configFilesFolder\\\": \\\"/home/daba/Oracle/network/admin\\\",\\n    \\\"[oraclesql]\\\": {\\n        \\\"editor.suggest.showSnippets\\\": true,\\n        \\\"editor.quickSuggestions\\\": {\\n            \\\"comments\\\": \\\"on\\\",\\n            \\\"strings\\\": \\\"on\\\",\\n            \\\"other\\\": \\\"on\\\"\\n        }\\n    },\\n    // \\\"mssql.connections\\\": [\\n    //     {\\n    //         \\\"server\\\": \\\"misetl\\\",\\n    //         \\\"database\\\": \\\"\\\",\\n    //         \\\"authenticationType\\\": \\\"SqlLogin\\\",\\n    //         \\\"user\\\": \\\"cmalliopoulos\\\",\\n    //         \\\"password\\\": \\\"\\\",\\n    //         \\\"emptyPasswordInput\\\": false,\\n    //         \\\"savePassword\\\": true,\\n    //         \\\"profileName\\\": \\\"cmalliopoulos@misetl\\\",\\n    //         \\\"encrypt\\\": \\\"Mandatory\\\",\\n    //         \\\"trustServerCertificate\\\": true,\\n    //         \\\"connectTimeout\\\": 15,\\n    //         \\\"commandTimeout\\\": 30,\\n    //         \\\"applicationName\\\": \\\"vscode-mssql\\\",\\n    //         \\\"displayName\\\": \\\"cmalliopoulos@misetl\\\"\\n    //     },\\n    //     {\\n    //         \\\"server\\\": \\\"misetl\\\",\\n    //         \\\"database\\\": \\\"\\\",\\n    //         \\\"authenticationType\\\": \\\"SqlLogin\\\",\\n    //         \\\"user\\\": \\\"tableau_sa\\\",\\n    //         \\\"password\\\": \\\"\\\",\\n    //         \\\"emptyPasswordInput\\\": false,\\n    //         \\\"savePassword\\\": true,\\n    //         \\\"profileName\\\": \\\"tableau_sa@misetl\\\",\\n    //         \\\"encrypt\\\": \\\"Mandatory\\\",\\n    //         \\\"trustServerCertificate\\\": true,\\n    //         \\\"displayName\\\": \\\"tableau_sa@misetl\\\"\\n    //     }\\n    // ],\\n    // \\\"mssql.enableQueryHistoryCapture\\\": false,\\n    // \\\"mssql.enableRichExperiences\\\": true,\\n    // \\\"mssql.autoDisableNonTSqlLanguageService\\\": false,\\n    // \\\"oracledevtools.connectionConfiguration.walletFileFolder\\\": \\\"/home/daba/Oracle/network/admin\\\",\\n    // \\\"oracledevtools.bookmarkFileFolder\\\": \\\"/home/daba/Oracle/oracle.oracledevtools\\\",\\n    // \\\"oracledevtools.download.otherFolder\\\": \\\"/home/daba/downloads\\\",\\n\\n    // Configure [glob patterns](https://aka.ms/vscode-glob-patterns) of file associations to languages (for example `\\\"*.extension\\\": \\\"html\\\"`). \\n    // Patterns will match on the absolute path of a file if they contain a path separator and will match on the name of the file otherwise. \\n    // These have precedence over the default associations of the languages installed.\\n    \\\"files.associations\\\": {\\n        \\\"*.plsql\\\": \\\"oracle\\\",\\n        \\\"*.ddl\\\": \\\"oracle\\\",\\n        \\\"*.dml\\\": \\\"oracle\\\",\\n        \\\"*.pks\\\": \\\"oracle\\\",\\n        \\\"*.pkb\\\": \\\"oracle\\\",\\n        \\\"*.sqlite\\\": \\\"sqlite\\\",\\n        \\\"*.sql\\\": \\\"sql\\\"\\n    },\\n    \\\"terminal.integrated.tabs.enabled\\\": false,\\n    \\\"terminal.integrated.lineHeight\\\": 1.2,\\n    \\\"explorer.confirmDelete\\\": false,\\n\\n    \\n    // l a t e x - w o r k s h o p\\n    // - - - - - - - - - - - - - -\\n    \\\"latex-workshop.latex.autoBuild.run\\\": \\\"onSave\\\",\\n    \\\"latex-workshop.latex.autoClean.run\\\": \\\"onFailed\\\",\\n    \\\"latex-workshop.latex.recipe.default\\\": \\\"latexmk (xelatex)\\\",\\n\\n    // Make LaTeX workshop add-on open pdf in a new tab in the same editor group\\n    \\\"latex-workshop.view.pdf.tab.editorGroup\\\": \\\"current\\\",\\n    // Make LaTeX Workshop PDF pages and viewer background use a dark/inverted view\\n    \\\"latex-workshop.view.pdf.color.dark.backgroundColor\\\": \\\"#1e1e1e\\\",\\n\\n    \\\"latex-workshop.latex.recipes\\\": [\\n        {\\n        \\\"name\\\": \\\"latexmk (xelatex)\\\",\\n        \\\"tools\\\": [\\\"latexmk-xelatex\\\"]\\n        },\\n        {\\n        \\\"name\\\": \\\"latexmk (pdflatex)\\\",\\n        \\\"tools\\\": [\\\"latexmk-pdflatex\\\"]\\n        },\\n        {\\n        \\\"name\\\": \\\"latexmk (lualatex)\\\",\\n        \\\"tools\\\": [\\\"latexmk-lualatex\\\"]\\n        }\\n    ],\\n\\n    \\\"latex-workshop.latex.tools\\\": [\\n        {\\n        \\\"name\\\": \\\"latexmk-xelatex\\\",\\n        \\\"command\\\": \\\"latexmk\\\",\\n        \\\"args\\\": [\\n            \\\"-xelatex\\\",\\n            \\\"-synctex=1\\\",\\n            \\\"-interaction=nonstopmode\\\",\\n            \\\"-file-line-error\\\",\\n            \\\"%DOC%\\\"\\n        ]\\n        },\\n        {\\n        \\\"name\\\": \\\"latexmk-pdflatex\\\",\\n        \\\"command\\\": \\\"latexmk\\\",\\n        \\\"args\\\": [\\n            \\\"-pdf\\\",\\n            \\\"-synctex=1\\\",\\n            \\\"-interaction=nonstopmode\\\",\\n            \\\"-file-line-error\\\",\\n            \\\"%DOC%\\\"\\n        ]\\n        },\\n        {\\n        \\\"name\\\": \\\"latexmk-lualatex\\\",\\n        \\\"command\\\": \\\"latexmk\\\",\\n        \\\"args\\\": [\\n            \\\"-lualatex\\\",\\n            \\\"-synctex=1\\\",\\n            \\\"-interaction=nonstopmode\\\",\\n            \\\"-file-line-error\\\",\\n            \\\"%DOC%\\\"\\n        ]\\n        }\\n    ],    \\n\\n\\n    // G i t  a n d  G i t h u b\\n    // - - -  - - -  - - - - - -\\n    \\\"git.openRepositoryInParentFolders\\\": \\\"always\\\",\\n    \\\"github.copilot.enable\\\": {\\n        \\\"*\\\": false,\\n        \\\"plaintext\\\": false,\\n        \\\"markdown\\\": false,\\n        \\\"scminput\\\": false\\n    },\\n    \\\"jupyter.askForKernelRestart\\\": false,\\n    \\\"cSpell.language\\\": \\\"en,el\\\",\\n    \\\"cSpell.enabledFileTypes\\\": {\\n        \\\"oracle\\\": false,\\n        \\\"dockerfile\\\": false,\\n        \\\"markdown\\\": true\\n    },\\n    \\\"window.newWindowProfile\\\": \\\"Default\\\",\\n    \\\"mssql.enableRichExperiences\\\": true,\\n    \\\"mssql.connections\\\": [\\n        {\\n            \\\"authenticationType\\\": \\\"SqlLogin\\\",\\n            \\\"connectTimeout\\\": 15,\\n            \\\"applicationName\\\": \\\"vscode-mssql\\\",\\n            \\\"profileName\\\": \\\"cmalliopoulos@misetl\\\",\\n            \\\"server\\\": \\\"misetl\\\",\\n            \\\"user\\\": \\\"cmalliopoulos\\\",\\n            \\\"savePassword\\\": true,\\n            \\\"password\\\": \\\"\\\",\\n            \\\"database\\\": \\\"dwh\\\",\\n            \\\"trustServerCertificate\\\": true,\\n            \\\"groupId\\\": \\\"ROOT\\\",\\n            \\\"id\\\": \\\"F8463FBD-A043-42F7-B1BD-2B2C7837A94F\\\",\\n            \\\"profileSource\\\": 0\\n        }\\n    ],\\n    \\\"mssql.autoDisableNonTSqlLanguageService\\\": true,\\n    \\\"terminal.external.osxExec\\\": \\\"iterm2.app\\\",\\n    \\\"terminal.integrated.enableMultiLinePasteWarning\\\": \\\"never\\\",\\n    \\\"workbench.startupEditor\\\": \\\"none\\\",\\n    // \\\"gitlens.autolinks\\\": [\\n    //     {\\n    //         \\\"prefix\\\": \\\"RAI-36686\\\",\\n    //         \\\"url\\\": \\\"https://relationalai.atlassian.net/browse/RAI-36686\\\"\\n    //     }\\n    // ],\\n    \\\"cSpell.enabled\\\": false,\\n    \\\"cmake.showConfigureWithDebuggerNotification\\\": false,\\n    \\\"docker.extension.dockerEngineAvailabilityPrompt\\\": false,\\n    \\\"markdown.preview.breaks\\\": true,\\n    \\\"mssql.connectionGroups\\\": [\\n        {\\n            \\\"name\\\": \\\"ROOT\\\",\\n            \\\"id\\\": \\\"ROOT\\\"\\n        }\\n    ],\\n    \\\"workbench.settings.applyToAllProfiles\\\": [\\n        \\\"terminal.integrated.stickyScroll.enabled\\\"\\n    ],\\n    \\\"terminal.integrated.stickyScroll.enabled\\\": false,\\n    \\\"github.copilot.nextEditSuggestions.enabled\\\": true,\\n    \\\"editor.accessibilitySupport\\\": \\\"off\\\",\\n    \\\"gitlens.ai.model\\\": \\\"vscode\\\",\\n    \\\"gitlens.ai.vscode.model\\\": \\\"copilot:gpt-4.1\\\",\\n    \\\"editor.fontFamily\\\": \\\"JetBrains Mono\\\",\\n    \\\"editor.fontLigatures\\\": true,\\n    // \\\"workbench.iconTheme\\\": \\\"vscode-jetbrains-icon-theme-2023-dark\\\",\\n    // \\\"jetbrains-titlebar.cssPath\\\": {\\n    //     \\\"501-20-/Users/christos\\\": \\\"/Applications/Visual Studio Code.app/Contents/Resources/app/out/vs/workbench/workbench.desktop.main.css\\\"\\n    // },\\n    // \\\"sqldeveloper.datagrid.fontFamily\\\": \\\"'Droid Sans Mono', monospace\\\",\\n    \\\"http.systemCertificatesNode\\\": true,\\n    \\\"chat.tools.urls.autoApprove\\\": {\\n        \\\"https://code.visualstudio.com\\\": true,\\n        \\\"https://github.com/microsoft/vscode/wiki/*\\\": true,\\n        \\\"https://docs.astral.sh\\\": true,\\n        \\\"https://*.astral.sh\\\": true\\n    },\\n    \\\"cSpell.enabledSchemes\\\": {\\n        \\\"comment\\\": true,\\n        \\\"file\\\": true,\\n        \\\"gist\\\": true,\\n        \\\"repo\\\": true,\\n        \\\"sftp\\\": true,\\n        \\\"untitled\\\": true,\\n        \\\"vscode-notebook-cell\\\": true,\\n        \\\"vscode-scm\\\": true,\\n        \\\"vscode-userdata\\\": true,\\n        \\\"vscode-vfs\\\": true,\\n        \\\"vsls\\\": true,\\n        \\\"overleaf-workshop\\\": true\\n    },\\n    \\\"chat.tools.terminal.autoApprove\\\": {\\n        \\\"kpsewhich\\\": true,\\n        \\\"printf\\\": true,\\n        \\\"fc-list\\\": true,\\n        \\\"system_profiler\\\": true,\\n        \\\"awk\\\": true,\\n        \\\"latexmk\\\": true,\\n        \\\"true\\\": true,\\n        \\\"uv\\\": true,\\n        \\\"/^pwd && which python && python --version && uv pip show setuptools && python -c 'import sys; print\\\\\\\\(sys\\\\\\\\.executable\\\\\\\\); print\\\\\\\\(\\\\\\\"\\\\\\\\\\\\\\\\n\\\\\\\"\\\\\\\\.join\\\\\\\\(sys\\\\\\\\.path\\\\\\\\[:5\\\\\\\\]\\\\\\\\)\\\\\\\\); from snowflake\\\\\\\\.snowpark import session; print\\\\\\\\(session\\\\\\\\)'$/\\\": {\\n            \\\"approve\\\": true,\\n            \\\"matchCommandLine\\\": true\\n        }\\n    },\\n    \\\"workbench.editorAssociations\\\": {\\n        \\\"*.copilotmd\\\": \\\"vscode.markdown.preview.editor\\\",\\n        \\\"*.pdf\\\": \\\"overleaf-workshop.pdfViewer\\\",\\n        \\\"*.parquet\\\": \\\"duckdb.dataFileViewer\\\",\\n        \\\"*.csv\\\": \\\"duckdb.dataFileViewer\\\",\\n        \\\"*.tsv\\\": \\\"duckdb.dataFileViewer\\\",\\n        \\\"*.xlsx\\\": \\\"duckdb.dataFileViewer\\\"\\n    },\\n    \\\"makefile.configureOnOpen\\\": true,\\n    \\\"explorer.fileNesting.patterns\\\": {\\n        \\\"*.ts\\\": \\\"${capture}.js\\\",\\n        \\\"*.js\\\": \\\"${capture}.js.map, ${capture}.min.js, ${capture}.d.ts\\\",\\n        \\\"*.jsx\\\": \\\"${capture}.js\\\",\\n        \\\"*.tsx\\\": \\\"${capture}.ts\\\",\\n        \\\"tsconfig.json\\\": \\\"tsconfig.*.json\\\",\\n        \\\"package.json\\\": \\\"package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock\\\",\\n        \\\"*.sqlite\\\": \\\"${capture}.${extname}-*\\\",\\n        \\\"*.db\\\": \\\"${capture}.${extname}-*\\\",\\n        \\\"*.sqlite3\\\": \\\"${capture}.${extname}-*\\\",\\n        \\\"*.db3\\\": \\\"${capture}.${extname}-*\\\",\\n        \\\"*.sdb\\\": \\\"${capture}.${extname}-*\\\",\\n        \\\"*.s3db\\\": \\\"${capture}.${extname}-*\\\"\\n    },\\n    \\\"[sql]\\\": {\\n        \\\"editor.wordSeparators\\\": \\\"`~!$%^&*()-=+[{]}\\\\\\\\|;:'\\\\\\\",.<>/?\\\"\\n    },\\n    \\\"chat.viewSessions.orientation\\\": \\\"stacked\\\",\\n    // // Using the light mode\\n    // // \\\"indentRainbow.indicatorStyle\\\": \\\"light\\\",\\n    // // we use a simple 1 pixel wide line\\n    // \\\"indentRainbow.lightIndicatorStyleLineWidth\\\": 0,\\n    // \\\"indentRainbow.colors\\\": [\\n    //     \\\"rgba(255,255,64,0.04)\\\",\\n    //     \\\"rgba(127,255,127,0.02)\\\",\\n    //     \\\"rgba(255,127,255,0.04)\\\",\\n    //     \\\"rgba(79,236,236,0.04)\\\"\\n    // ],\\n    // // The indent color if the number of spaces is not a multiple of \\\"tabSize\\\".\\n    // \\\"indentRainbow.errorColor\\\": \\\"rgba(10,32,32,0.01)\\\",\\n    // // The indent color when there is a mix between spaces and tabs.\\n    // // To be disabled this coloring set this to an empty string.\\n    // \\\"indentRainbow.tabmixColor\\\": \\\"rgba(10,32,32,0.01)\\\"\\n}\"}","keybindings":"{\"keybindings\":\"// Place your key bindings in this file to override the defaults\\n[\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+d\\\",\\n        \\\"command\\\": \\\"workbench.view.extension.objectExplorer\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"alt+cmd+d\\\",\\n        \\\"command\\\": \\\"-workbench.view.extension.objectExplorer\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+c\\\",\\n        \\\"command\\\": \\\"mssql.connect\\\",\\n        \\\"when\\\": \\\"editorTextFocus && editorLangId == 'sql'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+c\\\",\\n        \\\"command\\\": \\\"-mssql.connect\\\",\\n        \\\"when\\\": \\\"editorTextFocus && editorLangId == 'sql'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+shift+e\\\",\\n        \\\"command\\\": \\\"-cursorLineEndSelect\\\",\\n        \\\"when\\\": \\\"textInputFocus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+f2\\\",\\n        \\\"command\\\": \\\"workbench.action.toggleMaximizedPanel\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"cmd+t cmd+k\\\",\\n        \\\"command\\\": \\\"workbench.action.terminal.kill\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+cmd+u\\\",\\n        \\\"command\\\": \\\"editor.action.transformToUppercase\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+cmd+l\\\",\\n        \\\"command\\\": \\\"editor.action.transformToLowercase\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"alt+cmd+e\\\",\\n        \\\"command\\\": \\\"mssql.runCurrentStatement\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+e\\\",\\n        \\\"command\\\": \\\"-sqldeveloper.connection.folder.edit\\\",\\n        \\\"when\\\": \\\"activeViewlet == 'workbench.view.extension.sqldeveloper-explorer'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+n\\\",\\n        \\\"command\\\": \\\"-sqldeveloper.connection.add\\\",\\n        \\\"when\\\": \\\"activeViewlet == 'workbench.view.extension.sqldeveloper-explorer'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+f9\\\",\\n        \\\"command\\\": \\\"-workbench.action.chat.previousFileTree\\\",\\n        \\\"when\\\": \\\"chatIsEnabled && inChat\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+f9\\\",\\n        \\\"command\\\": \\\"workbench.debug.viewlet.action.disableAllBreakpoints\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+c\\\",\\n        \\\"command\\\": \\\"-workbench.action.terminal.openNativeConsole\\\",\\n        \\\"when\\\": \\\"!terminalFocus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+c\\\",\\n        \\\"command\\\": \\\"-sqldeveloper.connections.focus\\\",\\n        \\\"when\\\": \\\"activeViewlet == 'workbench.view.extension.sqldeveloper-explorer'\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+c\\\",\\n        \\\"command\\\": \\\"sqldeveloper.connections.focus\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+cmd+enter\\\",\\n        \\\"command\\\": \\\"sqlite.runDocumentQuery\\\",\\n        \\\"when\\\": \\\"editorLangId =~ /(sql|sqlite)/\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"shift+cmd+q\\\",\\n        \\\"command\\\": \\\"-sqlite.runDocumentQuery\\\",\\n        \\\"when\\\": \\\"editorLangId =~ /(sql|sqlite)/\\\"\\n    },\\n    {\\n        \\\"key\\\": \\\"ctrl+; m\\\",\\n        \\\"command\\\": \\\"-jupyter.changeCellToMarkdown\\\",\\n        \\\"when\\\": \\\"editorTextFocus && jupyter.hascodecells && !jupyter.webExtension && !notebookEditorFocused\\\"\\n    }\\n]\",\"platform\":1}","extensions":"[{\"identifier\":{\"id\":\"aaron-bond.better-comments\",\"uuid\":\"7a0110bb-231a-4598-aa1b-0769ea46d28b\"},\"displayName\":\"Better Comments\",\"applicationScoped\":false},{\"identifier\":{\"id\":\"akamud.vscode-theme-onelight\",\"uuid\":\"ee33fd31-7bb4-4252-8368-fdd5bcd94cf8\"},\"displayName\":\"Atom One Light Theme